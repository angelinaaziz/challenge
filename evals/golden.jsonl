# Hand-labeled ground truth for the Bead take-home samples. Each row is
# (control_dir, sample_id, attribute_text, verdict). Matching is done by
# normalized attribute_text so provider-specific slugs don't matter.
#
# Reasoning is in the "notes" field — kept short. Every SUCCESS/FAIL/FURTHER
# is defensible from the raw evidence, not from what the models happened to say.
{"control_dir": "data/independent-code-review", "sample_id": "sample-1", "attribute_text": "Code Reviews are performed prior to committing a change to the main branch", "verdict": "SUCCESS", "notes": "PR #62754 shows 'Merged' badge with jakebailey merging after review; RyanCavanaugh approved."}
{"control_dir": "data/independent-code-review", "sample_id": "sample-1", "attribute_text": "Code Review approvals are performed by independent code reviewers", "verdict": "SUCCESS", "notes": "Author=jakebailey, reviewer=RyanCavanaugh. Two named humans, independence preserved."}
{"control_dir": "data/independent-code-review", "sample_id": "sample-1", "attribute_text": "Testing is performed in accordance with the testing policy", "verdict": "SUCCESS", "notes": "PR is a test-only maintenance change (tests/cases + tests/baselines only). Falls under the documented exception 'Refactoring with No Behavioral Changes'. CI green with 15-job matrix, coverage artifact produced."}
{"control_dir": "data/independent-code-review", "sample_id": "sample-2", "attribute_text": "Code Reviews are performed prior to committing a change to the main branch", "verdict": "SUCCESS", "notes": "PR #31272 shows 'Merged' badge; dsherret approved with 'LGTM' before merge."}
{"control_dir": "data/independent-code-review", "sample_id": "sample-2", "attribute_text": "Code Review approvals are performed by independent code reviewers", "verdict": "SUCCESS", "notes": "Author=bartlomieju, reviewer=dsherret. Independent humans."}
{"control_dir": "data/independent-code-review", "sample_id": "sample-2", "attribute_text": "Testing is performed in accordance with the testing policy", "verdict": "FURTHER_EVIDENCE_REQUIRED", "notes": "No coverage report screenshot provided in this sample. CI green but coverage numbers not visible. Cannot judge threshold compliance without evidence."}
{"control_dir": "data/user-access-review", "sample_id": "sample-1", "attribute_text": "Access reviews are performed on a periodic basis (e.g. quarterly)", "verdict": "SUCCESS", "notes": "Cover sheet declares 'Periodic (Quarterly) User Access Review' for Q2 2026, completed 2026-06-30."}
{"control_dir": "data/user-access-review", "sample_id": "sample-1", "attribute_text": "Access is reviewed and approved by an appropriate system or data owner", "verdict": "SUCCESS", "notes": "Cover!B11 identifies reviewer Priya Nadkarni, Director Finance Systems (System Owner). Named, appropriate, and different from preparer."}
{"control_dir": "data/user-access-review", "sample_id": "sample-1", "attribute_text": "Inappropriate or excessive access identified during the review is remediated in a timely manner", "verdict": "FAIL", "notes": "Reperformance found 2 terminated-but-active users (Danielle Goodwin, Kevin Lewis). Reviewer flagged only Danielle for revocation; Kevin Lewis was marked 'Retain' despite being terminated in HRIS. Reviewer missed an inappropriate-access instance — remediation not performed."}
# --- Synthetic Change Management control (proves generalization) ------------
{"control_dir": "data/change-management", "sample_id": "sample-1", "attribute_text": "Every production change has a corresponding change request that documents scope, risk classification, and rollback plan", "verdict": "SUCCESS", "notes": "CHG-2026-0847 change request has scope, Medium risk, rollback plan, named requester + approver, planned window."}
{"control_dir": "data/change-management", "sample_id": "sample-1", "attribute_text": "Production changes are approved by an authorised change approver prior to deployment", "verdict": "FURTHER_EVIDENCE_REQUIRED", "notes": "CAB Change Approver Priya Nadkarni is documented (independent from requester, approval timestamp before deployment). BUT policy requires 2 approvers for Normal changes (Change Coordinator + CAB Change Approver). Change Coordinator role not named in evidence — cannot confirm full approval chain from what is on the record. Not FAIL because CAB reference is documented; not SUCCESS because full policy chain unverified."}
{"control_dir": "data/change-management", "sample_id": "sample-1", "attribute_text": "Pre-deployment testing is completed and evidence retained before release", "verdict": "SUCCESS", "notes": "pre-deployment-test-results.xlsx shows all 12 documented test cases PASS across functional/regression/rollback/performance categories, with sign-off from Marcus Bell 2026-06-23 15:10 UTC. Summary sheet declares 42 executed / 42 passed / 0 failed."}
{"control_dir": "data/change-management", "sample_id": "sample-2", "attribute_text": "Every production change has a corresponding change request that documents scope, risk classification, and rollback plan", "verdict": "SUCCESS", "notes": "CHG-2026-0912 documents scope, Medium risk, rollback plan, planned window. Documentation completeness is satisfied — approver-authority is judged under attribute 2 separately (atomic attribute isolation)."}
