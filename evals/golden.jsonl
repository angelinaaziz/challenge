# Hand-labelled ground truth for the Bead take-home samples. Each row is one
# `(control × sample × attribute)` triple with the expected verdict.
#
# id       : stable identifier — `<control>-<sample>-<slug>`. Slug encodes category.
# category : short tag for scoreboard slicing (review, independence, testing,
#            cadence, ownership, remediation, documentation, approval,
#            testing-evidence).
# verdict  : SUCCESS | FAIL | FURTHER_EVIDENCE_REQUIRED.
# notes    : one-sentence rationale. Not scored — but the reason lives here so
#            a debrief reviewer can see the label reasoning.
#
# Matching is done by normalised attribute_text so provider-specific slugs
# don't affect scoring.

{"id": "icr-sample1-review", "category": "review", "control_dir": "data/independent-code-review", "sample_id": "sample-1", "attribute_text": "Code Reviews are performed prior to committing a change to the main branch", "verdict": "SUCCESS", "notes": "PR #62754 shows 'Merged' badge with jakebailey merging after review; RyanCavanaugh approved."}
{"id": "icr-sample1-independence", "category": "independence", "control_dir": "data/independent-code-review", "sample_id": "sample-1", "attribute_text": "Code Review approvals are performed by independent code reviewers", "verdict": "SUCCESS", "notes": "Author=jakebailey, reviewer=RyanCavanaugh. Two named humans, independence preserved."}
{"id": "icr-sample1-testing", "category": "testing", "control_dir": "data/independent-code-review", "sample_id": "sample-1", "attribute_text": "Testing is performed in accordance with the testing policy", "verdict": "SUCCESS", "notes": "PR is a test-only maintenance change (tests/cases + tests/baselines only). Falls under the documented exception 'Refactoring with No Behavioral Changes'. CI green with 15-job matrix, coverage artifact produced."}
{"id": "icr-sample2-review", "category": "review", "control_dir": "data/independent-code-review", "sample_id": "sample-2", "attribute_text": "Code Reviews are performed prior to committing a change to the main branch", "verdict": "SUCCESS", "notes": "PR #31272 shows 'Merged' badge; dsherret approved with 'LGTM' before merge."}
{"id": "icr-sample2-independence", "category": "independence", "control_dir": "data/independent-code-review", "sample_id": "sample-2", "attribute_text": "Code Review approvals are performed by independent code reviewers", "verdict": "SUCCESS", "notes": "Author=bartlomieju, reviewer=dsherret. Independent humans."}
{"id": "icr-sample2-testing", "category": "testing", "control_dir": "data/independent-code-review", "sample_id": "sample-2", "attribute_text": "Testing is performed in accordance with the testing policy", "verdict": "FURTHER_EVIDENCE_REQUIRED", "notes": "No coverage report screenshot provided in this sample. CI green but coverage numbers not visible. Cannot judge threshold compliance without evidence."}
{"id": "uar-sample1-cadence", "category": "cadence", "control_dir": "data/user-access-review", "sample_id": "sample-1", "attribute_text": "Access reviews are performed on a periodic basis (e.g. quarterly)", "verdict": "SUCCESS", "notes": "Cover sheet declares 'Periodic (Quarterly) User Access Review' for Q2 2026, completed 2026-06-30."}
{"id": "uar-sample1-ownership", "category": "ownership", "control_dir": "data/user-access-review", "sample_id": "sample-1", "attribute_text": "Access is reviewed and approved by an appropriate system or data owner", "verdict": "SUCCESS", "notes": "Cover!B11 identifies reviewer Priya Nadkarni, Director Finance Systems (System Owner). Named, appropriate, and different from preparer."}
{"id": "uar-sample1-remediation", "category": "remediation", "control_dir": "data/user-access-review", "sample_id": "sample-1", "attribute_text": "Inappropriate or excessive access identified during the review is remediated in a timely manner", "verdict": "FAIL", "notes": "Reperformance found 2 terminated-but-active users (Danielle Goodwin, Kevin Lewis). Reviewer flagged only Danielle for revocation; Kevin Lewis was marked 'Retain' despite being terminated in HRIS. Reviewer missed an inappropriate-access instance — remediation not performed."}
