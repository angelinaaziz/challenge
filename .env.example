ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Model IDs (override defaults if needed)
# Current defaults are the strongest available models as of July 2026.
CLAUDE_MODEL=claude-opus-4-8
OPENAI_MODEL=gpt-5.4
# Gemini 3.x pro is preview-only right now; when GA lands, swap to `gemini-3-pro`.
# Any Gemini model that supports generateContent + JSON schema will work — see
# https://ai.google.dev/gemini-api/docs/models for the current list.
GEMINI_MODEL=gemini-3.1-pro-preview
